# Optional for Vercel demo. If empty, the app uses a built-in demo secret.
# For public demos, set a long random value in Vercel Project Settings → Environment Variables.
JWT_SECRET=

# Optional but recommended after deployment.
NEXT_PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app
AUTH_COOKIE_SECURE=true

# Payment routes exist but checkout demo does not require real payment.
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
